{
  "packages": [
    "nodejs@22",
    "git",
    "curl",
    "unzip",
    "neovim@latest",
    "ripgrep",
    "fd",
    "zellij@latest",
    "zsh@latest",
    "fzf",
    "zoxide",
    "atuin",
    "bat",
    "eza",
    "carapace",
    "zsh-autocomplete",
    "zsh-autosuggestions",
    "zsh-syntax-highlighting",
    "jq",
    "yq",
    "gh",
    "lazygit",
    "delta",
    "duf",
    "btop",
    "htop",
    "ncdu",
    "tree",
    "wget",
    "rsync",
    "openssl",
    "age",
    "sops",
    "direnv",
    "just",
    "gnumake",
    "gcc",
    "python312",
    "python312Packages.pip",
    "uv",
    "go",
    "rustup",
    "docker-client",
    "docker-compose",
    "kubernetes-helm",
    "kubectl",
    "k9s",
    "terraform",
    "opentofu",
    "ansible",
    "httpie",
    "xh",
    "nmap",
    "dnsutils",
    "whois",
    "tcpdump",
    "mtr",
    "pre-commit",
    "shellcheck",
    "shfmt",
    "chezmoi"
  ],
  "env": {
    "NPM_CONFIG_PREFIX": "$HOME/.npm-global"
  },
  "shell": {
    "init_hook": [
      "export PATH=$HOME/.npm-global/bin:$PATH",
      "export PATH=$HOME/.local/bin:$PATH",
      "echo '🚀 VPS cockpit environment ready'"
    ],
    "scripts": {
      "setup": "./scripts/setup.sh",
      "gentle-install": "gentle-ai install --agent pi",
      "pi-plugins": "./scripts/install-pi-plugins.sh",
      "doctor": [
        "node -v",
        "npm -v",
        "git --version",
        "zsh --version",
        "nvim --version | head -1",
        "rg --version | head -1",
        "fd --version",
        "fzf --version | head -1",
        "zoxide --version",
        "atuin --version",
        "bat --version",
        "eza --version",
        "carapace --version",
        "jq --version",
        "yq --version",
        "gh --version | head -1",
        "lazygit --version",
        "delta --version",
        "duf --version",
        "btop --version",
        "htop --version | head -1",
        "ncdu --version | head -1",
        "tree --version",
        "wget --version | head -1",
        "rsync --version | head -1",
        "openssl version",
        "age --version",
        "sops --version",
        "direnv --version",
        "just --version",
        "make --version | head -1",
        "gcc --version | head -1",
        "python3.12 --version",
        "pip --version",
        "uv --version",
        "go version",
        "rustup --version | head -1",
        "docker --version",
        "docker-compose --version",
        "helm version --short",
        "kubectl version --client=true",
        "k9s version --short",
        "terraform version | head -1",
        "tofu version | head -1",
        "ansible --version | head -1",
        "http --version",
        "xh --version",
        "nmap --version | head -1",
        "dig -v",
        "whois --version | head -1",
        "tcpdump --version | head -1",
        "mtr --version | head -1",
        "pre-commit --version",
        "shellcheck --version | grep version:",
        "shfmt --version",
        "chezmoi --version",
        "zellij --version",
        "pi --version",
        "gentle-ai --version",
        "codex --version",
        "claude --version"
      ],
      "agent": "pi",
      "mcp-render": "./scripts/render-mcp.sh",
      "zellij-install": "./scripts/install-zellij-autostart.sh",
      "work": "./scripts/work.sh",
      "zsh-install": "./scripts/install-zsh.sh",
      "work-reset": "./scripts/work.sh --reset",
      "work-update": "./scripts/work-update.sh",
      "bootstrap": "./scripts/bootstrap.sh",
      "ai-clis": "./scripts/install-ai-clis.sh"
    }
  }
}
