{
  "packages": [
    "nodejs@22",
    "git",
    "curl",
    "unzip",
    "neovim@latest",
    "ripgrep",
    "fd",
    "zellij@latest",
    "zsh@latest",
    "fzf",
    "zoxide",
    "atuin",
    "bat",
    "eza",
    "carapace",
    "zsh-autocomplete",
    "zsh-autosuggestions",
    "zsh-syntax-highlighting",
    "zsh-powerlevel10k"
  ],
  "env": {
    "NPM_CONFIG_PREFIX": "$HOME/.npm-global"
  },
  "shell": {
    "init_hook": [
      "export PATH=$HOME/.npm-global/bin:$PATH",
      "export PATH=$HOME/.local/bin:$PATH",
      "echo '🚀 VPS cockpit environment ready'"
    ],
    "scripts": {
      "setup": "./scripts/setup.sh",
      "gentle-install": "gentle-ai install --agent pi",
      "pi-plugins": "./scripts/install-pi-plugins.sh",
      "doctor": [
        "node -v",
        "npm -v",
        "git --version",
        "zsh --version",
        "nvim --version | head -1",
        "rg --version | head -1",
        "fd --version",
        "fzf --version | head -1",
        "zoxide --version",
        "atuin --version",
        "bat --version",
        "eza --version",
        "carapace --version",
        "zellij --version",
        "pi --version",
        "gentle-ai --version"
      ],
      "agent": "pi",
      "mcp-render": "./scripts/render-mcp.sh",
      "zellij-install": "./scripts/install-zellij-autostart.sh",
      "work": "./scripts/work.sh",
      "zsh-install": "./scripts/install-zsh.sh"
    }
  }
}
